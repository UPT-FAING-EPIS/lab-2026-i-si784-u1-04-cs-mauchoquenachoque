@page
@model Shorten.Pages.UrlMapping.DetailsModel
@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>UrlMapping</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            Original URL
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.UrlMapping.OriginalUrl)
        </dd>
        <dt class="col-sm-2">
            Shortened URL
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.UrlMapping.ShortenedUrl)
        </dd>
    </dl>
</div>
<div>
    <a asp-page="./Edit" asp-route-id="@Model.UrlMapping.Id">Edit</a> |
    <a asp-page="./Index">Back to List</a>
</div>
